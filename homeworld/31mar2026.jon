          "tool_uses": [
            {
              "id": "tooluse_VdIYdhirt6BS4WVN4ZrhJs",
              "name": "fs_write",
              "orig_name": "fs_write",
              "args": {
                "command": "create",
                "file_text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>FoFworld — Prehistoric World Generator</title>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { background: #0a0a14; color: #d4c9a8; font-family: 'Georgia', serif; min-height: 100vh; }\n\n  header {\n    text-align: center;\n    padding: 18px 0 10px;\n    background: linear-gradient(180deg, #0d1a2e 0%, #0a0a14 100%);\n    border-bottom: 1px solid #2a3a50;\n  }\n  header h1 { font-size: 2rem; letter-spacing: 4px; color: #8ecae6; text-shadow: 0 0 20px #1a6a9a; }\n  header p  { font-size: 0.85rem; color: #7a8a7a; margin-top: 4px; letter-spacing: 2px; }\n\n  .controls {\n    display: flex; align-items: center; justify-content: center; gap: 14px;\n    padding: 12px; flex-wrap: wrap;\n  }\n  .controls label { font-size: 0.85rem; color: #9ab; }\n  .controls input[type=number] {\n    width: 90px; padding: 5px 8px; background: #1a2030; border: 1px solid #3a5070;\n    color: #d4c9a8; border-radius: 4px; font-size: 0.9rem;\n  }\n  button {\n    padding: 7px 20px; background: #1a4a6a; border: 1px solid #3a7aaa;\n    color: #8ecae6; border-radius: 4px; cursor: pointer; font-size: 0.9rem;\n    transition: background 0.2s;\n  }\n  button:hover { background: #2a6a9a; }\n  button:disabled { opacity: 0.5; cursor: default; }\n\n  #status { font-size: 0.8rem; color: #6a8a6a; min-width: 160px; text-align: center; }\n\n  .map-wrap {\n    display: flex; justify-content: center; padding: 10px 20px 0;\n    position: relative;\n  }\n  canvas {\n    border: 2px solid #2a3a50;\n    cursor: crosshair;\n    image-rendering: pixelated;\n    max-width: 100%;\n  }\n\n  #tooltip {\n    position: fixed; background: rgba(10,15,25,0.92); border: 1px solid #3a5070;\n    padding: 7px 12px; border-radius: 5px; font-size: 0.8rem; pointer-events: none;\n    display: none; color: #c8d8c8; z-index: 100; line-height: 1.6;\n  }\n\n  .legend {\n    display: flex; flex-wrap: wrap; justify-content: center; gap: 8px;\n    padding: 14px 20px 20px; max-width: 900px; margin: 0 auto;\n  }\n  .legend-item {\n    display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: #9aaa9a;\n  }\n  .legend-swatch {\n    width: 14px; height: 14px; border-radius: 2px; border: 1px solid #3a4a3a; flex-shrink: 0;\n  }\n</style>\n</head>\n<body>\n\n<header>\n  <h1>🌿 FoFworld</h1>\n  <p>PREHISTORIC EARTH — 60% OCEAN · VAST JUNGLES · ANCIENT MOUNTAINS</p>\n</header>\n\n<div class=\"controls\">\n  <label>Seed: <input type=\"number\" id=\"seedInput\" value=\"42\" min=\"0\" max=\"99999\"></label>\n  <button id=\"genBtn\" onclick=\"generate()\">Generate World</button>\n  <button onclick=\"randomSeed()\">🎲 Random</button>\n  <span id=\"status\">Ready</span>\n</div>\n\n<div class=\"map-wrap\">\n  <canvas id=\"map\"></canvas>\n</div>\n\n<div id=\"tooltip\"></div>\n\n<div class=\"legend\" id=\"legend\"></div>\n\n<script>\nconst BIOME_LABELS = {\n  deep_ocean:    \"Deep Ocean\",\n  ocean:         \"Ocean\",\n  shallow_ocean: \"Shallow Ocean\",\n  lake:          \"Lake\",\n  river:         \"River\",\n  beach:         \"Beach\",\n  jungle:        \"Jungle\",\n  rainforest:    \"Rainforest\",\n  forest:        \"Forest\",\n  grassland:     \"Grassland\",\n  savanna:       \"Savanna\",\n  desert:        \"Desert\",\n  mountain:      \"Mountain\",\n  snow_mountain: \"Snow Mountain\",\n  tundra:        \"Tundra\",\n  ice:           \"Ice Cap\",\n};\n\nlet worldData = null;\n\nfunction rgb(c) { return `rgb(${c[0]},${c[1]},${c[2]})`; }\n\nfunction buildLegend(colors) {\n  const el = document.getElementById(\"legend\");\n  el.innerHTML = \"\";\n  for (const [key, color] of Object.entries(colors)) {\n    const item = document.createElement(\"div\");\n    item.className = \"legend-item\";\n    item.innerHTML = `<div class=\"legend-swatch\" style=\"background:${rgb(color)}\"></div>${BIOME_LABELS[key] || key}`;\n    el.appendChild(item);\n  }\n}\n\nfunction drawWorld(data) {\n  const canvas = document.getElementById(\"map\");\n  canvas.width  = data.width;\n  canvas.height = data.height;\n  const ctx = canvas.getContext(\"2d\");\n  const imgData = ctx.createImageData(data.width, data.height);\n  const px = data.pixels;\n  for (let i = 0; i < px.length; i++) {\n    const base = i * 4;\n    imgData.data[base]   = px[i][0];\n    imgData.data[base+1] = px[i][1];\n    imgData.data[base+2] = px[i][2];\n    imgData.data[base+3] = 255;\n  }\n  ctx.putImageData(imgData, 0, 0);\n  worldData = data;\n  buildLegend(data.biome_colors);\n}\n\nasync function generate() {\n  const seed = parseInt(document.getElementById(\"seedInput\").value) || 42;\n  const btn  = document.getElementById(\"genBtn\");\n  const status = document.getElementById(\"status\");\n  btn.disabled = true;\n  status.textContent = \"Generating world…\";\n  try {\n    const res  = await fetch(`/api/world?seed=${seed}`);\n    const data = await res.json();\n    drawWorld(data);\n    status.textContent = `Seed ${data.seed} · sea level ${(data.sea_level*100).toFixed(1)}%`;\n  } catch(e) {\n    status.textContent = \"Error: \" + e.message;\n  }\n  btn.disabled = false;\n}\n\nfunction randomSeed() {\n  document.getElementById(\"seedInput\").value = Math.floor(Math.random() * 99999);\n  generate();\n}\n\n// Tooltip on hover\nconst canvas = document.getElementById(\"map\");\nconst tooltip = document.getElementById(\"tooltip\");\ncanvas.addEventListener(\"mousemove\", e => {\n  if (!worldData) return;\n  const rect = canvas.getBoundingClientRect();\n  const scaleX = worldData.width  / rect.width;\n  const scaleY = worldData.height / rect.height;\n  const mx = Math.floor((e.clientX - rect.left) * scaleX);\n  const my = Math.floor((e.clientY - rect.top)  * scaleY);\n  if (mx < 0 || my < 0 || mx >= worldData.width || my >= worldData.height) return;\n  const idx = my * worldData.width + mx;\n  const px  = worldData.pixels[idx];\n  // Find biome by color match\n  let biomeName = \"unknown\";\n  for (const [key, c] of Object.entries(worldData.biome_colors)) {\n    if (c[0] === px[0] && c[1] === px[1] && c[2] === px[2]) { biomeName = key; break; }\n  }\n  tooltip.style.display = \"block\";\n  tooltip.style.left = (e.clientX + 14) + \"px\";\n  tooltip.style.top  = (e.clientY - 10) + \"px\";\n  tooltip.innerHTML = `<b>${BIOME_LABELS[biomeName] || biomeName}</b><br>x:${mx} y:${my}`;\n});\ncanvas.addEventListener(\"mouseleave\", () => { tooltip.style.display = \"none\"; });\n\n// Auto-generate on load\ngenerate();\n</script>\n</body>\n</html>\n",
                "path": "/Users/hon/aiapr2026/homeworld/fofworld/templates/index.html"
              },
